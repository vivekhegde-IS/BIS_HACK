# BIS Finder — Environment Variables
# Copy this file to .env and fill in the values

# Required: Anthropic Claude API key for rationale generation
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: OpenAI key (if used as a fallback)
OPENAI_API_KEY=

# Flask environment (development | production)
FLASK_ENV=development

# CORS: Vercel frontend URL (set this in Render dashboard for production)
# Example: https://bis-finder.vercel.app
FRONTEND_URL=http://localhost:3000
